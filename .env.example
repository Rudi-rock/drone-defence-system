# Backend Configuration
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_APP=backend/app.py

# Server
HOST=0.0.0.0
PORT=5000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Simulation Defaults
DEFAULT_DRONES=5
DEFAULT_THREATS=2
DEFAULT_DURATION=60
DEFAULT_TIMESTEP=0.05

# Logging
LOG_LEVEL=INFO
